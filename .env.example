# Copy to .env.local and fill in. Next.js auto-loads .env.local for the app.

# --- Admin (required for multi-user auth) ---
# The bootstrap admin account, seeded on first run from these vars. There is no
# public registration — the admin creates every other user from the console.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-now
ADMIN_NAME=Admin

# Secret for signing session cookies. If unset, a random one is generated and
# persisted to <data>/.session-secret. Set it explicitly for stable sessions.
# KATK_SECRET=

# Master key used to encrypt stored per-user API keys (AES-256-GCM). If unset,
# it is derived from KATK_SECRET. Changing either orphans stored keys (users
# just re-enter them). Set explicitly for stable at-rest encryption.
# KATK_ENCRYPTION_KEY=

# --- AI (optional) ---
# Shared server API key. Used for any user who hasn't added their own (unless the
# admin marked them "require own key"). Without it, users must bring their own.
ANTHROPIC_API_KEY=
# Default model for the SHARED server key — always used on that key regardless of
# a user's dropdown choice, so shared usage stays cost-controlled. Users on their
# OWN key can pick a model in Settings. Bias this cheap (e.g. Haiku).
# KATK_MODEL=claude-haiku-4-5

# --- Storage (optional) ---
# Root dir for app.db + per-user databases (default: data).
# KATK_DATA_DIR=data
